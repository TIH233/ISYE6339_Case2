{
  "eval_id": 1,
  "eval_name": "task5-hub-mip",
  "prompt": "Draft the latex report for Task 5. This task is about selecting 50 regional hubs using a MIP. Make sure to include the formulation.",
  "assertions": [
    {
      "id": "no_first_person",
      "description": "No first-person subjects ('I', 'we', 'our') appear in the text",
      "check": "grep -iE '\\bI\\b|\\bwe\\b|\\bour\\b' output — should return nothing"
    },
    {
      "id": "has_section_header",
      "description": "File contains a \\section{} LaTeX header for Task 5",
      "check": "grep '\\\\section{' output — should match"
    },
    {
      "id": "has_subsections",
      "description": "At least 2 \\subsection{} headers present",
      "check": "Count \\\\subsection{ occurrences — should be >= 2"
    },
    {
      "id": "has_mip_formulation",
      "description": "MIP objective function present in math environment (\\min or \\max inside equation/align)",
      "check": "grep '\\\\min\\|\\\\max\\|\\\\text{minimize}\\|\\\\text{s.t.}' — should match"
    },
    {
      "id": "has_constraints",
      "description": "MIP constraints are written out (not just the objective)",
      "check": "grep -i 'subject to\\|s\\.t\\.\\|constraint' — should match"
    },
    {
      "id": "no_preamble",
      "description": "No LaTeX preamble",
      "check": "grep '\\\\documentclass' — should return nothing"
    },
    {
      "id": "mentions_hub_count",
      "description": "References the 50 regional hubs result",
      "check": "grep '50' — should match (hub count)"
    }
  ]
}
